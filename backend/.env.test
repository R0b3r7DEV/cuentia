# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'

# Integration tests run against a local SQLite database (no server needed), so they
# are fast and work in CI without a database service.
# ES: Los tests de integración usan una base de datos SQLite local (sin servidor),
# así son rápidos y funcionan en CI sin un servicio de base de datos.
DATABASE_URL="sqlite:///:memory:"
